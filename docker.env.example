# LM Studio connection (docker-compose overrides this to host.docker.internal)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Models loaded in LM Studio
VISION_MODEL=qwen/qwen3-vl-8b
CHAT_MODEL=qwen2.5-math-7b-instruct@q4_k_s

# Embedding model (downloaded automatically on first run)
EMBEDDING_MODEL=Alibaba-NLP/gte-large-en-v1.5

# Chunking
CHUNK_SIZE=1500
CHUNK_OVERLAP=300

# Retrieval
RETRIEVAL_K=8
